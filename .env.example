# ============================================================================
# ResearchDeOpcoes — exemplo de configuração.
# Copie para ".env" (no Dell) e preencha. O .env NUNCA vai para o Git.
#   PowerShell:  Copy-Item .env.example .env
# ============================================================================

# --- Google Sheets (Service Account) ---------------------------------------
# Caminho do JSON da conta de serviço e ID da planilha-espelho.
GOOGLE_CREDENTIALS_FILE=credenciais.json
SPREADSHEET_ID=COLE_AQUI_O_ID_DA_PLANILHA_ESPELHO

# Nomes das abas (sobrescreva só se forem diferentes dos defaults).
TAB_ATIVAS=PAINEL_ATIVAS
TAB_LUCROS=SELECAO_OPCOES_MAIORES_LUCROS
TAB_VOLUMES=SELECAO_MAIORES_VOLUMES
TAB_M9M21=RANKING_TENDENCIA_M9M21
TAB_CORREL=RANKING_CORREL_IBOV
TAB_DADOS_ATIVOS=DADOS_ATIVOS
TAB_LOGS=LOGS
TAB_HIST_ESCUDO=ESCUDO_HISTORICO
TAB_HIST_RADAR=RADAR_HISTORICO
TAB_MONITOR=MONITOR

# Linha (1-based) do cabeçalho real. Painel_Ativas pode ter preâmbulo —
# se o header estiver, por ex., na linha 10, ajuste abaixo.
TAB_ATIVAS_HEADER_ROW=1

# Locale decimal das abas: a planilha-espelho inteira está em pt-BR (vírgula
# decimal). Todas as abas usam "," por padrão. Só mexa se mudar a formatação.
TAB_ATIVAS_DECIMAL=,
TAB_DADOS_ATIVOS_DECIMAL=,

# --- OpLab API (relógio de ponto) ------------------------------------------
OPLAB_BASE_URL=https://api.oplab.com.br/v3
OPLAB_TOKEN=COLE_AQUI_SEU_TOKEN_OPLAB
OPLAB_MARKET_STATUS_PATH=/market/status
OPLAB_OPEN_STATUS=A
OPLAB_TIMEOUT=15

# --- E-mail (pager via SMTP) -----------------------------------------------
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
EMAIL_USER=seu_email@gmail.com
# Gmail: gere uma "Senha de app" (App Password) — NÃO use a senha normal.
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_SENDER=seu_email@gmail.com
ALERT_RECIPIENTS=brunotrolo@gmail.com

# --- Runtime ---------------------------------------------------------------
MARKET_TZ=America/Sao_Paulo
# DRY_RUN=true -> roda a análise, mas NÃO envia e-mail nem grava na planilha.
DRY_RUN=false
# AUDIT_VERBOSE=true -> registra TODOS os passos/leituras/cálculos na aba LOGS.
AUDIT_VERBOSE=true

# --- Thresholds ESCUDO (Módulo 1) ------------------------------------------
ESCUDO_BUYBACK_MULT_OTM=2.0
ESCUDO_BUYBACK_MULT_OTM_CRIT=3.0
ESCUDO_BUYBACK_MULT_ATM=1.5
ESCUDO_DELTA_WARN=0.30
ESCUDO_DELTA_URGENT=0.35
ESCUDO_DELTA_ATM=0.45
ESCUDO_DTE_CRITICAL=15
ESCUDO_LOSS_VS_MAXLOSS_PCT=0.50
ESCUDO_ONLY_SHORT_LEGS=true
# Gamma alto = pré-perigo (aceleração do delta)
ESCUDO_GAMMA_MAX=0.05
# Risco de carteira: concentração setorial (HHI) e exposição direcional ao IBOV
ESCUDO_HHI_MAX=0.50
ESCUDO_IBOV_EXPOSURE_MAX=0.80
ESCUDO_IBOV_CORREL_THRESHOLD=0.50

# --- Thresholds RADAR (Módulo 2) -------------------------------------------
RADAR_OPTION_TYPE=PUT
RADAR_IV_RANK_MIN=50
RADAR_SPOT_STRIKE_RATIO_MIN=1.02
RADAR_MIN_OPTION_VOLUME_FIN=1
RADAR_MIN_UNDERLYING_VOLUME=0
RADAR_REQUIRE_TREND_UP=false
# Restringe às ações monitoradas em DADOS_ATIVOS (e com opções listadas).
RADAR_USE_WHITELIST=true
RADAR_REQUIRE_HAS_OPTIONS=true
# Janela de DTE (dias corridos): sweet spot de venda de prêmio
RADAR_DTE_MIN=21
RADAR_DTE_MAX=45
# Filtro de spread bid-ask (precisa de BID/ASK por opção na aba de lucros)
RADAR_USE_SPREAD_FILTER=false
RADAR_BID_ASK_SPREAD_MAX=0.20
RADAR_TOP_N=5

# --- Dimensionamento de posição (opcional) ---------------------------------
# Capital disponível p/ sugerir nº de contratos no Radar (0 = desliga).
CAPITAL_DISPONIVEL=0
RISK_PER_TRADE=0.02
